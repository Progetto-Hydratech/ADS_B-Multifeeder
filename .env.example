# Beast receiver source (ultrafeeder or another ADS-B decoder)
BEASTHOST=ultrafeeder
BEASTPORT=30005

# Timezone
TZ=Europe/Rome

# Antenna position (REQUIRED for ADS-B Exchange)
LAT=xx.xxxx
LONG=xx.xxxx
ALT=xxx

# FlightRadar24 — get your key at flightradar24.com/share-your-data
FR24_KEY=

# FlightAware — generated automatically on first run, then set here to keep it stable
FLIGHTAWARE_FEEDER_ID=

# ADS-B Exchange — generate with: uuidgen
ADSBX_UUID=
ADSBX_SITENAME=MyFeeder
